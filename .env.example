# =============================================================================
# VERCEL ENV VARS — Add these to your Vercel project settings
# =============================================================================

# --- Firebase Client SDK (required) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin SDK (required — for server-side Firestore reads/writes) ---
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# --- App URL (required — for email links and payment return URLs) ---
NEXT_PUBLIC_APP_URL=

# --- Cloudflare Worker URLs + API Key (required — Next.js calls these workers) ---
# Pick a random string (e.g. openssl rand -hex 32) and use the SAME value as
# API_KEY in every worker's wrangler.toml. The worker checks X-API-Key header
# against this value — that's the auth mechanism between your services.
#
# NEXT_PUBLIC_ prefix required: these are called from client-side components
# (checkout pages, subscription pages, etc.)
NEXT_PUBLIC_WORKER_API_KEY=
NEXT_PUBLIC_QUORUM_PAYMENTS_URL=https://quorum-payments.<your-subdomain>.workers.dev
NEXT_PUBLIC_QUORUM_UPLOADS_URL=https://quorum-uploads.<your-subdomain>.workers.dev
NEXT_PUBLIC_QUORUM_COMM_URL=https://quorum-comm.<your-subdomain>.workers.dev
NEXT_PUBLIC_QUORUM_SUBSCRIPTIONS_URL=https://quorum-subscriptions.<your-subdomain>.workers.dev
# Cron is server-only (called by Cloudflare Worker, not browser)
QUORUM_CRON_URL=https://quorum-cron.<your-subdomain>.workers.dev

# --- Org SMTP Password Encryption (required — 32-byte hex key for AES-256-GCM.
#     Used by /api/org/smtp to encrypt org SMTP passwords before saving to Firestore.) ---
SMTP_ENCRYPTION_KEY=

# --- Google Analytics (optional) ---
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=


# =============================================================================
# NOT NEEDED IN VERCEL — handled by Cloudflare Workers
# =============================================================================
# PESAPAL_CONSUMER_KEY/SECRET/BASE_URL  → quorum-payments worker secret
# SMTP_HOST/PORT/USER/PASS              → quorum-comm uses Resend, not Nodemailer
# DEFAULT_FROM_EMAIL/NAME               → quorum-comm uses Resend
# CRON_SECRET                           → quorum-cron worker secret
# WEBHOOK_SECRET                        → quorum-payments worker secret
# ALLOWED_ORIGIN                        → all workers' CORS config
# RESEND_API_KEY / RESEND_FROM_EMAIL    → quorum-comm + quorum-subscriptions worker secrets


# =============================================================================
# CLOUDFLARE WORKER SETUP
# =============================================================================
# Each worker needs:
#   1. Set API_KEY in wrangler.toml [secrets] — SAME value as WORKER_API_KEY in Vercel
#   2. Set other secrets via `wrangler secret put <NAME>`
#
# quorum-payments:
#   wrangler.toml: API_KEY, ALLOWED_ORIGIN
#   secrets: PESAPAL_CONSUMER_KEY, PESAPAL_CONSUMER_SECRET, FIREBASE_ADMIN_CLIENT_EMAIL,
#            FIREBASE_ADMIN_PRIVATE_KEY, CRON_SECRET, WEBHOOK_SECRET,
#            QUORUM_SUBSCRIPTIONS_URL
#
# quorum-uploads:
#   wrangler.toml: FIREBASE_API_KEY, ALLOWED_ORIGIN
#
# quorum-cron:
#   wrangler.toml: API_KEY, CRON_SECRET, QUORUM_PAYMENTS_URL, QUORUM_COMM_URL,
#                  QUORUM_SUBSCRIPTIONS_URL
#
# quorum-comm:
#   wrangler.toml: API_KEY, ALLOWED_ORIGIN
#   secrets: RESEND_API_KEY, RESEND_FROM_EMAIL
#
# quorum-subscriptions:
#   wrangler.toml: API_KEY, ALLOWED_ORIGIN, QUORUM_PAYMENTS_URL, QUORUM_COMM_URL,
#                  CRON_SECRET, APP_URL
#   secrets: FIREBASE_ADMIN_CLIENT_EMAIL, FIREBASE_ADMIN_PRIVATE_KEY,
#            RESEND_API_KEY, RESEND_FROM_EMAIL
